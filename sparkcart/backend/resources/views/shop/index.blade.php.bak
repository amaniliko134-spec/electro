<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Baraka Solar Shop - Premium Power Marketplace</title>
    <meta name="csrf-token" content="{{ csrf_token() }}">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; transition: background-color 0.2s, border-color 0.2s; }
        body { font-family: system-ui, -apple-system, sans-serif; background-color: #f4f6f9; color: #0f172a; line-height: 1.5; }
        body.dark-mode { background-color: #0f172a; color: #f8fafc; }
        body.dark-mode nav { background-color: #1e40af; }
        body.dark-mode .category-block, body.dark-mode .card, body.dark-mode .modal-content, body.dark-mode .cart-drawer { background-color: #1e293b !important; border-color: #334155 !important; }
        body.dark-mode .product-title, body.dark-mode .modal-title, body.dark-mode h2, body.dark-mode .cart-item-name, body.dark-mode h3 { color: #f8fafc !important; }
        body.dark-mode .product-desc, body.dark-mode .modal-desc, body.dark-mode .price-lbl { color: #94a3b8 !important; }
        body.dark-mode .image-frame, body.dark-mode .modal-img-frame { background-color: #1e293b !important; border-color: #334155 !important; }
        body.dark-mode .setting-menu-panel { background-color: #1e293b !important; border-color: #475569 !important; color: #f8fafc !important; }
        body.dark-mode .setting-menu-item:hover { background-color: #334155 !important; }

        nav { background-color: #1d4ed8; position: sticky; top: 0; z-index: 50; box-shadow: 0 4px 10px rgba(0,0,0,0.08); }
        .nav-container { max-w: 92rem; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; height: 4.75rem; padding: 0 2rem; gap: 1.5rem; }
        .nav-logo { color: #ffffff; text-decoration: none; font-size: 1.75rem; font-weight: 900; display: flex; align-items: center; gap: 0.5rem; white-space: nowrap; }
        .search-form { flex-grow: 1; max-w: 32rem; display: flex; position: relative; }
        .search-input { width: 100%; padding: 0.65rem 1rem 0.65rem 2.5rem; border-radius: 9999px; border: 2px solid transparent; background-color: #f1f5f9; font-size: 0.9rem; outline: none; }
        .search-input:focus { background: white; border-color: #fb923c; }
        .search-icon-label { position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: #64748b; }
        .search-btn { position: absolute; right: 0.25rem; top: 50%; transform: translateY(-50%); background-color: #ff9900; border: none; padding: 0.45rem 1.25rem; border-radius: 9999px; color: white; font-weight: 700; cursor: pointer; }
        .nav-actions { display: flex; align-items: center; gap: 1rem; position: relative; }
        .settings-trigger-btn { background: rgba(255,255,255,0.15); color: white; border: none; padding: 0.55rem 1rem; border-radius: 0.5rem; font-weight: 700; font-size: 0.875rem; cursor: pointer; display: flex; align-items: center; gap: 0.35rem; }
        .setting-menu-panel { position: absolute; top: 3.5rem; right: 7rem; width: 16rem; background: white; border-radius: 0.75rem; border: 1px solid #e2e8f0; box-shadow: 0 10px 20px rgba(0,0,0,0.1); display: none; flex-direction: column; padding: 0.5rem 0; z-index: 60; }
        .setting-menu-panel.open { display: flex; }
        .setting-menu-item { padding: 0.65rem 1.25rem; text-decoration: none; color: #334155; font-size: 0.875rem; font-weight: 600; display: flex; align-items: center; justify-content: space-between; cursor: pointer; background: none; border: none; text-align: left; width: 100%; }
        .setting-menu-item:hover { background-color: #f1f5f9; color: #1d4ed8; }
        .basket-trigger-badge { color: #ffffff; background-color: #ff9900; padding: 0.55rem 1.35rem; border-radius: 9999px; font-weight: 800; font-size: 0.9rem; cursor: pointer; border: none; display: flex; align-items: center; gap: 0.5rem; }

        header { background: linear-gradient(135deg, #1e40af, #1e1b4b, #0f172a); color: #ffffff; padding: 4rem 1rem; text-align: center; border-bottom: 4px solid #ff9900; }
        header h1 { font-size: 2.5rem; font-weight: 800; margin-bottom: 0.75rem; }
        header p { color: #93c5fd; font-size: 1.15rem; max-w: 40rem; margin: 0 auto; }
        main { max-w: 92rem; margin: 0 auto; padding: 2.5rem 2rem; }
        .category-block { margin-bottom: 4rem; background: white; padding: 2rem; border-radius: 1.25rem; border: 1px solid #e2e8f0; }
        .category-heading { font-size: 1.5rem; font-weight: 800; padding-bottom: 0.75rem; margin-bottom: 1.5rem; color: #1e3a8a; border-bottom: 3px solid #1d4ed8; display: flex; align-items: center; justify-content: space-between; }
        .grid-container { display: grid; grid-template-columns: repeat(1, minmax(0, 1fr)); gap: 1.75rem; }
        @media (min-width: 640px) { .grid-container { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
        @media (min-width: 1024px) { .grid-container { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
        @media (min-width: 1300px) { .grid-container { grid-template-columns: repeat(4, minmax(0, 1fr)); } }
        .card { background-color: #ffffff; border-radius: 1rem; border: 1px solid #e2e8f0; overflow: hidden; display: flex; flex-direction: column; justify-content: space-between; position: relative; cursor: pointer; }
        .image-frame { height: 14rem; width: 100%; display: flex; align-items: center; justify-content: center; padding: 1.25rem; background: #ffffff; border-bottom: 1px solid #f1f5f9; }
        .image-frame img { object-fit: contain; height: 100%; width: 100%; }
        .modal-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.6); z-index: 200; display: none; align-items: center; justify-content: center; padding: 1.5rem; }
        .modal-content { background: white; width: 100%; max-width: 44rem; border-radius: 1.5rem; border: 1px solid #cbd5e1; overflow: hidden; display: grid; grid-template-columns: repeat(1, minmax(0, 1fr)); position: relative; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25); }
        @media (min-width: 640px) { .modal-content { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
        .modal-img-frame { height: 22rem; width: 100%; display: flex; align-items: center; justify-content: center; padding: 2rem; background: #ffffff; border-right: 1px solid #f1f5f9; }
        .modal-details-pane { padding: 2rem; display: flex; flex-direction: column; justify-content: space-between; }
        .close-modal-x { position: absolute; top: 1rem; right: 1.25rem; background: none; border: none; font-size: 1.75rem; font-weight: bold; color: #94a3b8; cursor: pointer; z-index: 10; }
        .close-modal-x:hover { color: #ef4444; }
    </style>
</head>
