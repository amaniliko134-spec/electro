    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const settingsTrigger = document.getElementById('settings-trigger');
            const settingMenuPanel = document.getElementById('setting-menu-panel');
            const themeToggleBtn = document.getElementById('theme-toggle-btn');
            const themeStatusLbl = document.getElementById('theme-status-lbl');
            const cartTrigger = document.getElementById('cart-trigger');
            const closeDrawer = document.getElementById('close-drawer');
            const cartDrawer = document.getElementById('cart-drawer');
            const drawerOverlay = document.getElementById('drawer-overlay');
            const badgeCountVal = document.getElementById('badge-count-val');
            const drawerTotalVal = document.getElementById('drawer-total-val');
            const checkoutBtn = document.getElementById('drawer-checkout-btn');
            const csrfToken = document.querySelector('meta[name="csrf-token"]').getAttribute('content');

            let activeModalProductPrice = 0, activeModalQuantity = 1;

            if(settingsTrigger) settingsTrigger.addEventListener('click', (e) => { e.stopPropagation(); settingMenuPanel.classList.toggle('open'); });
            document.addEventListener('click', () => settingMenuPanel.classList.remove('open'));

            if(localStorage.getItem('dark-theme') === 'true') { document.body.classList.add('dark-mode'); themeStatusLbl.textContent = 'DARK'; }
            themeToggleBtn.addEventListener('click', () => {
                const isDark = document.body.classList.toggle('dark-mode');
                localStorage.setItem('dark-theme', isDark);
                themeStatusLbl.textContent = isDark ? 'DARK' : 'LIGHT';
            });

            cartTrigger.addEventListener('click', () => { cartDrawer.style.right = '0'; drawerOverlay.style.display = 'block'; });
            closeDrawer.addEventListener('click', () => { cartDrawer.style.right = '-28rem'; drawerOverlay.style.display = 'none'; });
            drawerOverlay.addEventListener('click', () => { cartDrawer.style.right = '-28rem'; drawerOverlay.style.display = 'none'; window.closeProductModal(); closeAuthModal(); });

            if(checkoutBtn) {
                checkoutBtn.onclick = function() {
                    const drawerTotalText = document.getElementById('drawer-total-val').textContent;
                    const messageString = `Hello Baraka Solar Shop, I am ready to purchase the solar gear in my basket totaling ${drawerTotalText}.`;
                    window.open(`https://whatsapp.com{encodeURIComponent(messageString)}`, '_blank');
                };
            }

            window.triggerProductModal = function(id) {
                fetch(`/product/details/${id}`).then(res => res.json()).then(data => {
                    if(data.success) {
                        activeModalProductPrice = data.product.price; activeModalQuantity = 1;
                        document.getElementById('modal-qty-val').textContent = "1";
                        document.getElementById('modal-target-img').src = '/' + data.product.image_path;
                        document.getElementById('modal-target-title').textContent = data.product.name;
                        document.getElementById('modal-target-desc').textContent = data.product.description;
                        document.getElementById('modal-target-price').textContent = 'Ksh ' + Number(activeModalProductPrice).toLocaleString();

                        document.getElementById('modal-add-basket-btn').onclick = function() {
                            fetch(`/cart/update/${id}`, {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': csrfToken },
                                body: JSON.stringify({ quantity: activeModalQuantity })
                            }).then(res => res.json()).then(data => { if(data.success) window.location.reload(); });
                        };
                        document.getElementById('modal-instant-buy-btn').onclick = function() {
                            const singleItemMsg = `Hello Baraka Solar Shop, I want to purchase ${activeModalQuantity} unit(s) of "${data.product.name}" for a total value of Ksh ${(activeModalProductPrice * activeModalQuantity).toLocaleString()}.`;
                            window.open(`https://whatsapp.com{encodeURIComponent(singleItemMsg)}`, '_blank');
                        };
                        document.getElementById('product-detail-modal').style.display = 'flex'; drawerOverlay.style.display = 'block';
                    }
                });
            };
            window.closeProductModal = function() { document.getElementById('product-detail-modal').style.display = 'none'; if(cartDrawer.style.right !== '0') drawerOverlay.style.display = 'none'; };

            document.getElementById('modal-qty-plus').onclick = function() { activeModalQuantity++; document.getElementById('modal-qty-val').textContent = activeModalQuantity; document.getElementById('modal-target-price').textContent = 'Ksh ' + Number(activeModalProductPrice * activeModalQuantity).toLocaleString(); };
            document.getElementById('modal-qty-minus').onclick = function() { if(activeModalQuantity > 1) { activeModalQuantity--; document.getElementById('modal-qty-val').textContent = activeModalQuantity; document.getElementById('modal-target-price').textContent = 'Ksh ' + Number(activeModalProductPrice * activeModalQuantity).toLocaleString(); } };
            window.adjustBasketQty = function(id, directionCode) {
                const qtyTxtSpan = document.getElementById(`qty-display-${id}`);
                const linePriceSpan = document.getElementById(`item-line-total-${id}`);
                let currentItemCountVal = parseInt(qtyTxtSpan.textContent) + directionCode;
                if (currentItemCountVal <= 0) { killBasketItem(id); return; }

                qtyTxtSpan.textContent = currentItemCountVal;
                fetch(`/cart/update/${id}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': csrfToken },
                    body: JSON.stringify({ quantity: currentItemCountVal })
                }).then(res => res.json()).then(data => {
                    if(data.success) {
                        badgeCountVal.textContent = data.cart_count; drawerTotalVal.textContent = 'Ksh ' + data.cart_total;
                        const targetItemMeta = data.cart_items[id];
                        if(targetItemMeta) linePriceSpan.textContent = Number(targetItemMeta.price * targetItemMeta.quantity).toLocaleString(undefined, {minimumFractionDigits: 2});
                    }
                });
            };

            window.killBasketItem = function(id) {
                const targetCardRow = document.getElementById(`drawer-item-${id}`);
                fetch(`/cart/remove/${id}`, { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': csrfToken } }).then(res => res.json()).then(data => {
                    if(data.success) {
                        badgeCountVal.textContent = data.cart_count; drawerTotalVal.textContent = 'Ksh ' + data.cart_total;
                        if(targetCardRow) targetCardRow.remove();
                        if(data.cart_count === 0) window.location.reload();
                    }
                });
            };

            document.querySelectorAll('.add-to-cart-btn').forEach(btn => {
                btn.addEventListener('click', function(e) {
                    e.stopPropagation(); const id = this.getAttribute('data-id');
                    fetch(`/cart/add/${id}`, { method: 'POST', headers: { 'X-CSRF-TOKEN': csrfToken } }).then(res => res.json()).then(data => { if(data.success) window.location.reload(); });
                });
            });

            let currentAuthMode = 'login';
            window.openAuthModal = function(mode) {
                currentAuthMode = mode; document.getElementById('auth-modal-title').textContent = mode === 'login' ? 'Customer Profile Login' : 'Register Account';
                document.getElementById('auth-field-name-row').style.display = mode === 'login' ? 'none' : 'block';
                document.getElementById('auth-field-confirm-row').style.display = mode === 'login' ? 'none' : 'block';
                document.getElementById('auth-modal').style.display = 'flex'; drawerOverlay.style.display = 'block';
            };
            window.closeAuthModal = function() { document.getElementById('auth-modal').style.display = 'none'; if(cartDrawer.style.right !== '0') drawerOverlay.style.display = 'none'; };

            document.getElementById('auth-submit-btn').onclick = function() {
                const passField = document.getElementById('auth-input-password').value;
                const confirmField = document.getElementById('auth-input-confirm').value;
                const errLog = document.getElementById('auth-error-log');
                if(currentAuthMode === 'register' && passField !== confirmField) { errLog.textContent = "🔒 Match Error: Passwords do not match."; errLog.style.display = 'block'; return; }
                const payload = { email: document.getElementById('auth-input-email').value, password: passField, name: document.getElementById('auth-input-name').value };
                fetch(`/${currentAuthMode}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': csrfToken },
                    body: JSON.stringify(payload)
                }).then(res => res.json()).then(data => { if(data.success) { window.location.reload(); } else { errLog.textContent = data.message; errLog.style.display = 'block'; } });
            };
        });
    </script>
</body>
</html>
